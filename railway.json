{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'no build step — @lazarus/backend + core run as TypeScript via tsx'"
  },
  "deploy": {
    "startCommand": "pnpm --filter @lazarus/backend start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
