# Lazarus backend environment.
#
# Local dev: `docker compose up -d` then set DATABASE_URL to the compose Postgres.
# Railway injects DATABASE_URL and PORT automatically when you reference the
# Postgres plugin and deploy the service.

# Postgres connection string. Unset → in-memory index (no durability).
DATABASE_URL=postgres://lazarus:lazarus@localhost:5432/lazarus

# Bind address. Defaults to 127.0.0.1 (loopback). Set to 0.0.0.0 on Railway so
# the platform can route external traffic to the service.
HOST=127.0.0.1

# Listening port. Defaults to 8787; Railway injects its own PORT.
PORT=8787

# k-anonymity threshold (distinct witnesses before a snapshot is served).
LAZARUS_K=3

# --- Sybil-resistant witness tokens ---
# HMAC secret for server-issued witness tokens. MUST be set in production (else
# tokens use an ephemeral per-process secret that won't survive restarts).
LAZARUS_WITNESS_SECRET=
# Token lifetime in ms (default 86400000 = 24h).
LAZARUS_WITNESS_TTL_MS=

# --- TURN (P2P relay) ---
# Ephemeral TURN creds are minted server-side; the shared secret never ships to
# clients. Leave unset → /v1/turn-credentials returns public STUN only.
TURN_URLS=
TURN_SHARED_SECRET=
TURN_TTL_SECONDS=600

# --- Observability ---
LOG_LEVEL=info
# PostHog analytics (counts/sizes only — never urls/cids/titles). Unset → no-op.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# S3-compatible object storage for snapshot blobs (Railway bucket, Cloudflare
# R2, AWS S3, MinIO). Set endpoint + bucket + both keys to route blobs to object
# storage instead of Postgres; leave any unset to fall back to Postgres.
# S3_REGION defaults to "auto" (correct for Railway buckets and R2).
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
