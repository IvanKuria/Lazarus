    "compile": "wxt prepare && tsc --noEmit",
    "e2e": "playwright test",
    "prepare": "wxt prepare"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "wxt": "^0.20.26"
  },
  "dependencies": {
    "@lazarus/core": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
