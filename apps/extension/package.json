{
  "name": "@lazarus/extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Lazarus browser extension — the node in the distributed web-memory network.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
