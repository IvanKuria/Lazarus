# Backend origin the extension talks to. Only WXT_PUBLIC_* vars are inlined into
# the extension bundle at build time (WXT/Vite convention).
#
# Leave these UNSET for local dev — the clients fall back to the docker-compose
# backend (http://localhost:8787 / ws://localhost:8787/signal).
#
# For a production build, copy this to .env.production (untracked) and set the
# deployed Railway origin:
#   WXT_PUBLIC_API_BASE=https://<your-app>.up.railway.app
#   WXT_PUBLIC_SIGNAL_URL=wss://<your-app>.up.railway.app/signal

WXT_PUBLIC_API_BASE=http://localhost:8787
WXT_PUBLIC_SIGNAL_URL=ws://localhost:8787/signal
